# Copy this file to `.env` and fill in your own values. Never commit the real `.env`.

# --- Supabase Postgres connection (required) ---
# Supabase dashboard -> Connect -> "Session pooler" -> copy the URI.
# URL-encode special characters in the password (e.g. @ becomes %40).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres

# --- OpenAI (required for the Task 3 "areas to watch" narrative) ---
# Create a key at https://platform.openai.com/api-keys (needs a small amount of credits).
OPENAI_API_KEY=sk-...

# --- Optional: override the model (default: gpt-4o-mini) ---
# OPENAI_MODEL=gpt-4o-mini
